# CONFIGURACIÓN DE BETPREDICT TERMINAL
# Copia este archivo como .env y completa los valores

# --- PUERTO ---
PORT=3000

# --- LLAVES DE IA (Al menos una es requerida) ---
OPENAI_API_KEY=tu_openai_key_aqui
GEMINI_API_KEY=tu_gemini_key_aqui

# --- API DE DEPORTES (The Odds API) ---
THE_ODDS_API_KEY=tu_odds_api_key_aqui

# --- BASE DE DATOS (MongoDB Atlas) ---
# Si se deja vacío, se usará el modo In-Memory
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/betpredict

# --- CONFIGURACIÓN OPCIONAL ---
NODE_ENV=production
LOG_LEVEL=info
